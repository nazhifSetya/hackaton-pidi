# ==========================================================================
# .gitignore — Proyek Analisis Sentimen (Deep Learning / NLP)
# Mencakup proyek PLN Mobile (folder ini) + MyTelkomsel (fareynaldi/)
# ==========================================================================

# ── Python ────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ipynb_checkpoints/

# ── Virtual environment (JANGAN di-commit — besar & khusus mesin) ─────────
.venv/
venv/
env/
ENV/
.python-version           # hapus baris ini kalau mau simpan pin pyenv 3.10.20

# ── Jupyter ───────────────────────────────────────────────────────────────
*.ipynb_checkpoints
profile_default/
ipython_config.py

# ── Model & artefak ML (BESAR, bisa dibuat ulang dgn menjalankan notebook) ─
*.h5
*.hdf5
*.keras
*.joblib
*.pkl
*.pickle
*.pt
*.pth
*.ckpt
*.pb
*.onnx
*.safetensors

# ── Output fine-tune IndoBERT / HuggingFace (dibuat di Victus/GPU) ─────────
# Wildcard menutup indobert_pln_model/, indobert_mytelkomsel_model/, dll.
indobert_*_model/
indobert_ckpt/
**/indobert_*_model/
**/indobert_ckpt/
runs/
wandb/
.cache/
huggingface/

# ── Berkas submission & log ───────────────────────────────────────────────
*.zip                     # hasil paket submission (dibuat ulang saat butuh)
*.log
/tmp/
scratchpad/

# ── OS ────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
desktop.ini

# ── Editor / IDE ──────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── Data besar (OPSIONAL) ─────────────────────────────────────────────────
# Dataset TETAP di-commit secara default karena ini bagian dari submission
# & agar proyek reproducible di GitHub (masih di bawah batas 100 MB/file).
# Kalau repo jadi terlalu berat, hapus tanda # di bawah untuk mengabaikannya:
# submission/dataset_pln_reviews.csv
# submission/dataset_pln_labeled.csv
# fareynaldi/submission/dataset_mytelkomsel_reviews.csv
# fareynaldi/submission/dataset_mytelkomsel_labeled.csv
