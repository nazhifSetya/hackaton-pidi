# PGABL - Fine-tuned Chatbot Tim Legal berbasis RAG
# Template secrets. Copy to `.env` (NOT committed) dan isi nilainya.
# Di Colab: pakai Colab Secrets (menu kunci di kiri sidebar) — JANGAN commit `.env` real.

# HuggingFace Hub — scope Write (untuk push_to_hub). Generate di:
#   https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_write_scope_token_here

# Weights & Biases — untuk logging training. Generate di:
#   https://wandb.ai/authorize
WANDB_API_KEY=your_wandb_api_key_here

# (Opsional) Nama HF username untuk push model
HF_USERNAME=your_hf_username_here

# (Opsional) Nama W&B project untuk grouping runs
WANDB_PROJECT=PGABL-Nazhif
